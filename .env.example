# ZeroClaw Enterprise - Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Your LLM API key
OPENAI_API_KEY=sk-your-key-here

# Provider (default: openrouter)
PROVIDER=openrouter

# Model (recommended: google/gemma-4-27b-it for agentic behavior)
ZEROCLAW_MODEL=openrouter/google/gemma-4-27b-it

# Gateway binding (set to false for security)
ZEROCLAW_ALLOW_PUBLIC_BIND=false

# Host port for ZeroClaw gateway
HOST_PORT=42617

# Qdrant (optional - for vector memory)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# GitHub Token (optional)
# Get from: https://github.com/settings/tokens
# Scopes: repo, read:user, workflow
GITHUB_TOKEN=

# Notion Integration (optional)
# Get from: https://www.notion.so/my-integrations
NOTION_KEY=

# Telegram Bot Token (optional)
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Logging
RUST_LOG=info
RUST_BACKTRACE=1
